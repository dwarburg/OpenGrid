# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted to native line endings on checkout
*.c text
*.h text
*.cpp text
*.hpp text
*.cs text
*.js text
*.ts text
*.json text
*.md text
*.txt text
*.xml text
*.yml text
*.yaml text
*.html text
*.css text
*.scss text
*.sql text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.a binary
*.o binary
*.obj binary
*.pdb binary
*.lib binary
*.dll binary
*.class binary
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar.gz binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
